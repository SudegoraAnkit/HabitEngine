<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for HabitEngine to automate back up to the cloud on uninstall and device migration.
    See https://developer.android.com/about/versions/12/backup-restore#xml-changes for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="."/>
        <include domain="sharedpref" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="."/>
        <include domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
